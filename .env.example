# Environment template
# Copy this file to `.env` and fill in only the keys required by your selected backend.

# Always required:
OPENAI_API_KEY=

# Optional: required only when using `transcriber: deepgram`.
DEEPGRAM_API_KEY=

# Optional: required only for WhisperX/pyannote diarization.
HF_TOKEN=

# Optional: LangSmith tracing.
# Enable via `langsmith_tracing: true` in config.yaml or by adding LANGSMITH_TRACING=true in .env
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Optional: override the LangSmith API endpoint.
# Example EU endpoint: https://eu.api.smith.langchain.com
LANGSMITH_ENDPOINT=
